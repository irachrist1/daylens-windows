{
  "name": "daylens-windows",
  "productName": "Daylens",
  "version": "1.0.26",
  "description": "Cross-platform activity tracker that turns your laptop history into a searchable, AI-ready work timeline.",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "test:weekly-brief": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs --test ./tests/weeklyBrief.test.ts",
    "test:ai-chat": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs --test ./tests/weeklyBrief.test.ts ./tests/followUpChat.test.ts ./tests/appIdentityBranding.test.ts ./tests/onboardingFirstRun.test.ts ./tests/blockCleanup.test.ts ./tests/anthropicPromptCaching.test.ts ./tests/aiThreadSchema.test.ts ./tests/databaseBootstrap.test.ts ./tests/cliLaunch.test.ts ./tests/userData.test.ts ./tests/platformExpectations.test.ts",
    "test:entity-prompts": "cross-env ELECTRON_RUN_AS_NODE=1 electron --loader ./tests/support/ts-loader.mjs --test ./tests/routerHardPromptBenchmark.ts",
    "build:main": "cross-env STANDALONE_BUILD=1 vite build --config vite.main.config.ts",
    "build:preload": "cross-env STANDALONE_BUILD=1 vite build --config vite.preload.config.ts",
    "build:renderer": "cross-env STANDALONE_BUILD=1 vite build --config vite.renderer.config.ts",
    "build:all": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dist:win": "npm run build:all && electron-builder --win --config electron-builder.config.js",
    "dist:mac": "npm run build:all && electron-builder --mac zip dmg --config electron-builder.config.js",
    "dist:linux": "npm run build:all && electron-builder --linux AppImage deb rpm tar.gz --config electron-builder.config.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3,@paymoapp/active-window,keytar"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@google/genai": "^1.47.0",
    "@paymoapp/active-window": "^2.1.4",
    "@sentry/electron": "^7.11.0",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "openai": "^6.33.0",
    "posthog-node": "^5.28.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.0.0",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "lodash": "4.18.1",
    "protobufjs": "7.5.5"
  }
}
